---
import Layout from '../../components/Layout.astro';
import VerseList from '../../components/VerseList.astro';
import { href, shortTitle } from '../../lib/url';
import type { TopicsData, Topic } from '../../lib/types';
import data from '../../data/topics.json';

type NavLink = { slug: string; title: string } | null;

// Passages with at least this many verses are collapsed behind a disclosure.
const LONG = 8;

// Shared filled-button style for the expand disclosure and the "Read here" link.
const BTN =
  'inline-flex items-center gap-1 rounded-md bg-accent-100 px-3 py-1.5 text-sm font-medium text-accent-800 transition-colors hover:bg-accent-200 dark:bg-accent-900/50 dark:text-accent-200 dark:hover:bg-accent-800/70 cursor-pointer';

export function getStaticPaths() {
  const { topics } = data as TopicsData;
  const nav = (t?: Topic): NavLink => (t ? { slug: t.slug, title: t.title } : null);
  return topics.map((topic, i) => ({
    params: { slug: topic.slug },
    props: { topic, prev: nav(topics[i - 1]), next: nav(topics[i + 1]) },
  }));
}

const { topic, prev, next } = Astro.props as { topic: Topic; prev: NavLink; next: NavLink };
const verseCount = topic.passages.reduce((n, p) => n + p.verses.length, 0);
---

<Layout title={`${topic.title} — Scriptures of Jesus Christ`}>
  <a href={href()} class="inline-flex items-center gap-1 text-sm text-stone-500 hover:text-stone-800 dark:text-stone-400 dark:hover:text-stone-100">
    <span aria-hidden="true">←</span> All topics
  </a>

  <header class="mt-3 mb-8 border-b border-stone-200 pb-6 dark:border-stone-800">
    <p class="text-sm font-medium uppercase tracking-wide text-accent-700 dark:text-accent-400">Jesus Christ</p>
    <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{shortTitle(topic.title)}</h1>
    {!topic.seeAlso && (
      <p class="mt-2 text-sm text-stone-500 dark:text-stone-400">
        {verseCount.toLocaleString()} verses across {topic.refCount} {topic.refCount === 1 ? 'reference' : 'references'}
      </p>
    )}
  </header>

  {topic.seeAlso ? (
    <div class="rounded-xl border border-stone-200 bg-white p-6 dark:border-stone-800 dark:bg-stone-900">
      <p class="text-stone-600 dark:text-stone-300">This entry points to another topic:</p>
      <a
        class="mt-2 inline-flex items-center gap-1 text-lg font-semibold text-accent-700 hover:underline dark:text-accent-400"
        href={topic.seeAlso.external ? topic.seeAlso.url : href(`topics/${topic.seeAlso.slug}/`)}
        {...topic.seeAlso.external ? { target: '_blank', rel: 'noopener' } : {}}
      >
        {topic.seeAlso.title}
        {topic.seeAlso.external && <span aria-hidden="true" class="text-sm">↗</span>}
      </a>
    </div>
  ) : (
    <div id="passages" data-topic-title={shortTitle(topic.title)} class="space-y-7">
      {topic.passages.map((p, i) => (
        <>
          {p.fromSeeAlso && (i === 0 || !topic.passages[i - 1].fromSeeAlso) && (
            <h2 class="!mt-10 border-t border-stone-200 pt-6 text-sm font-semibold uppercase tracking-wide text-stone-500 dark:border-stone-800 dark:text-stone-400">
              See also
            </h2>
          )}
          <section id={`p-${i}`} data-ref={p.reference} class="scroll-mt-24">
            <div class="mb-1.5 flex items-baseline justify-between gap-3">
              <h3 class="font-semibold tracking-tight">
                <a href={p.churchUrl} target="_blank" rel="noopener">{p.reference}</a>
              </h3>
              <button
                data-bm
                type="button"
                aria-pressed="false"
                aria-label="Bookmark this passage"
                title="Bookmark this passage"
                class="shrink-0 text-stone-400 transition-colors hover:text-accent-700 dark:hover:text-accent-400"
              >
                <svg data-bm-off class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
                <svg data-bm-on class="hidden h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
              </button>
            </div>
            {p.chapterOnly ? (
              <div class="flex flex-wrap items-center gap-x-2 gap-y-2">
                <span class="reading text-stone-500 dark:text-stone-400">Cited as entire chapters.</span>
                <a href={p.churchUrl} target="_blank" rel="noopener" class={BTN}>Read Here <span aria-hidden="true">↗</span></a>
              </div>
            ) : p.verses.length >= LONG ? (
              <details class="passage">
                <summary class:list={['passage-summary', BTN]}>
                  <span class="det-closed">Show all {p.verses.length} verses <span aria-hidden="true">▾</span></span>
                  <span class="det-open">Collapse <span aria-hidden="true">▴</span></span>
                </summary>
                <VerseList verses={p.verses} churchUrl={p.churchUrl} class="mt-3" />
              </details>
            ) : (
              <VerseList verses={p.verses} churchUrl={p.churchUrl} />
            )}
          </section>
        </>
      ))}
    </div>
  )}

  <nav class="mt-12 grid grid-cols-2 gap-3 border-t border-stone-200 pt-6 dark:border-stone-800">
    {prev ? (
      <a
        href={href(`topics/${prev.slug}/`)}
        rel="prev"
        class="group rounded-xl border border-stone-200 px-4 py-3 transition hover:border-accent-400 dark:border-stone-800 dark:hover:border-accent-600"
      >
        <span class="block text-xs uppercase tracking-wide text-stone-400 dark:text-stone-500"><span aria-hidden="true">←</span> Previous</span>
        <span class="mt-0.5 block font-medium group-hover:underline">{shortTitle(prev.title)}</span>
      </a>
    ) : <span></span>}
    {next ? (
      <a
        href={href(`topics/${next.slug}/`)}
        rel="next"
        class="group rounded-xl border border-stone-200 px-4 py-3 text-right transition hover:border-accent-400 dark:border-stone-800 dark:hover:border-accent-600"
      >
        <span class="block text-xs uppercase tracking-wide text-stone-400 dark:text-stone-500">Next <span aria-hidden="true">→</span></span>
        <span class="mt-0.5 block font-medium group-hover:underline">{shortTitle(next.title)}</span>
      </a>
    ) : <span></span>}
  </nav>

  {/* Passage-level bookmarking. A single bookmark is stored; clicking a passage's
      icon makes it the bookmark (or clears it if it already is). */}
  <script is:inline>
    (() => {
      const list = document.getElementById('passages');
      if (!list) return;
      const KEY = 'jcs-bookmark';
      const topicTitle = list.getAttribute('data-topic-title') || '';
      const path = location.pathname;
      const read = () => { try { return JSON.parse(localStorage.getItem(KEY) || 'null'); } catch { return null; } };
      const buttons = Array.from(list.querySelectorAll('[data-bm]'));

      const urlFor = (btn) => path + '#' + btn.closest('section').id;
      const paint = () => {
        const cur = read();
        for (const btn of buttons) {
          const on = !!cur && cur.url === urlFor(btn);
          btn.classList.toggle('text-accent-700', on);
          btn.classList.toggle('dark:text-accent-400', on);
          btn.classList.toggle('text-stone-400', !on);
          btn.querySelector('[data-bm-on]').classList.toggle('hidden', !on);
          btn.querySelector('[data-bm-off]').classList.toggle('hidden', on);
          btn.setAttribute('aria-pressed', on ? 'true' : 'false');
        }
      };

      for (const btn of buttons) {
        btn.addEventListener('click', () => {
          const section = btn.closest('section');
          const url = urlFor(btn);
          const cur = read();
          try {
            if (cur && cur.url === url) {
              localStorage.removeItem(KEY);
            } else {
              localStorage.setItem(KEY, JSON.stringify({
                url,
                title: topicTitle,
                ref: section.getAttribute('data-ref'),
                savedAt: Date.now(),
              }));
            }
          } catch {}
          paint();
          window.dispatchEvent(new Event('jcs-bookmark-changed'));
        });
      }
      paint();

      // One-time onboarding hints, shown in sequence (each once, ever): first the
      // bookmark icon, then the passage heading link.
      const seen = (k) => { try { return !!localStorage.getItem(k); } catch { return true; } };
      const showHint = (target, html, key, after) => {
        const tip = document.createElement('div');
        tip.className = 'fixed z-30 max-w-[16rem] cursor-pointer rounded-lg bg-stone-900 px-3.5 py-2.5 text-base text-stone-50 shadow-lg dark:bg-stone-100 dark:text-stone-900';
        tip.setAttribute('role', 'status');
        tip.innerHTML = html + ' <span class="mt-2 ml-auto block w-fit rounded-md bg-white/15 px-2.5 py-1 text-sm font-medium dark:bg-black/10">Got it</span>';
        const arrow = document.createElement('div');
        arrow.className = 'fixed z-30 h-2.5 w-2.5 rotate-45 bg-stone-900 dark:bg-stone-100';
        document.body.append(tip, arrow);

        const place = () => {
          const r = target.getBoundingClientRect();
          const w = tip.offsetWidth;
          tip.style.left = Math.max(8, Math.min(r.left, innerWidth - w - 8)) + 'px';
          tip.style.top = r.bottom + 10 + 'px';
          arrow.style.left = r.left + r.width / 2 - 5 + 'px';
          arrow.style.top = r.bottom + 5 + 'px';
        };
        place();

        let raf = false;
        const onScroll = () => {
          if (raf) return;
          raf = true;
          requestAnimationFrame(() => { place(); raf = false; });
        };
        let done = false;
        const dismiss = () => {
          if (done) return;
          done = true;
          try { localStorage.setItem(key, '1'); } catch {}
          tip.remove();
          arrow.remove();
          removeEventListener('scroll', onScroll);
          removeEventListener('resize', place);
          if (after) after();
        };
        addEventListener('scroll', onScroll, { passive: true });
        addEventListener('resize', place);
        tip.addEventListener('click', dismiss);
        target.addEventListener('click', dismiss, { once: true });
        setTimeout(dismiss, 12000);
      };

      const firstLink = list.querySelector('section h3 a');
      const linkHint = () => {
        if (!seen('jcs-link-hint-seen') && firstLink) {
          showHint(firstLink, 'Tap a reference to open the full passage.', 'jcs-link-hint-seen');
        }
      };
      if (buttons.length && !seen('jcs-bm-hint-seen')) {
        showHint(buttons[0], 'Tap to save your place — pick it back up any time with <strong>Resume</strong> at the top.', 'jcs-bm-hint-seen', linkHint);
      } else {
        linkHint();
      }
    })();
  </script>
</Layout>
