---
import Layout from '../../components/Layout.astro';
import { href, shortTitle } from '../../lib/url';
import type { TopicsData, Topic } from '../../lib/types';
import data from '../../data/topics.json';

export function getStaticPaths() {
  const { topics } = data as TopicsData;
  return topics.map((topic) => ({ params: { slug: topic.slug }, props: { topic } }));
}

const { topic } = Astro.props as { topic: Topic };
const groupCount = topic.groups.length;
const verseCount = topic.groups.reduce((n, g) => n + g.verses.length, 0);
---

<Layout title={`${topic.title} — Scriptures of Jesus Christ`}>
  <a href={href()} class="inline-flex items-center gap-1 text-sm text-stone-500 hover:text-stone-800 dark:text-stone-400 dark:hover:text-stone-100">
    <span aria-hidden="true">←</span> All topics
  </a>

  <header class="mt-3 mb-8 border-b border-stone-200 pb-6 dark:border-stone-800">
    <p class="text-sm font-medium uppercase tracking-wide text-amber-700 dark:text-amber-500">Jesus Christ</p>
    <h1 class="mt-1 text-3xl font-bold tracking-tight sm:text-4xl">{shortTitle(topic.title)}</h1>
    {!topic.seeAlso && (
      <p class="mt-2 text-sm text-stone-500 dark:text-stone-400">
        {verseCount.toLocaleString()} verses across {groupCount} {groupCount === 1 ? 'passage' : 'passages'}
      </p>
    )}
  </header>

  {topic.seeAlso ? (
    <div class="rounded-xl border border-stone-200 bg-white p-6 dark:border-stone-800 dark:bg-stone-900">
      <p class="text-stone-600 dark:text-stone-300">This entry points to another topic:</p>
      <a
        class="mt-2 inline-flex items-center gap-1 text-lg font-semibold text-amber-700 hover:underline dark:text-amber-500"
        href={topic.seeAlso.external ? topic.seeAlso.url : href(`topics/${topic.seeAlso.slug}/`)}
        {...topic.seeAlso.external ? { target: '_blank', rel: 'noopener' } : {}}
      >
        {topic.seeAlso.title}
        {topic.seeAlso.external && <span aria-hidden="true" class="text-sm">↗</span>}
      </a>
    </div>
  ) : (
    <div class="space-y-8">
      {topic.groups.map((g) => (
        <section>
          <div class="mb-2 flex items-baseline justify-between gap-3">
            <h2 class="text-lg font-semibold tracking-tight">{g.reference}</h2>
            <a
              href={g.churchUrl}
              target="_blank"
              rel="noopener"
              class="shrink-0 text-sm text-amber-700 hover:underline dark:text-amber-500"
            >Full chapter <span aria-hidden="true">↗</span></a>
          </div>
          {g.chapterOnly ? (
            <p class="reading text-stone-500 dark:text-stone-400">
              Cited as a whole chapter — <a class="underline" href={g.churchUrl} target="_blank" rel="noopener">read it on churchofjesuschrist.org</a>.
            </p>
          ) : (
            <ol class="reading space-y-2">
              {g.verses.map((v) => (
                <li class="flex gap-2.5">
                  <span class="mt-0.5 shrink-0 select-none text-xs font-semibold text-amber-700/80 tabular-nums dark:text-amber-500/80">{v.num}</span>
                  <span>
                    {v.text ?? (
                      <em class="text-stone-500 dark:text-stone-400">
                        (text unavailable — <a class="underline" href={g.churchUrl} target="_blank" rel="noopener">read on churchofjesuschrist.org</a>)
                      </em>
                    )}
                  </span>
                </li>
              ))}
            </ol>
          )}
        </section>
      ))}
    </div>
  )}
</Layout>
